{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Plate",
    "scopeName": "source.plate",
    "patterns": [
        {
            "include": "#plate-directive"
        },
        {
            "include": "#html"
        }
    ],
    "repository": {
        "html": {
            "patterns": [
                {
                    "include": "#html-tag"
                },
                {
                    "begin": "(?=<)",
                    "end": "(?={{)",
                    "patterns": [
                        {
                            "include": "text.html.basic"
                        }
                    ],
                    "name": "meta.embedded.block.html"
                }
            ]
        },
        "html-tag": {
            "begin": "(</?)([a-zA-Z0-9:-]+)",
            "beginCaptures": {
                "1": {
                    "name": "punctuation.definition.tag.begin.html"
                },
                "2": {
                    "name": "entity.name.tag.html"
                }
            },
            "end": "(/?>)",
            "endCaptures": {
                "1": {
                    "name": "punctuation.definition.tag.end.html"
                }
            },
            "name": "meta.embedded.block.html meta.tag.html",
            "patterns": [
                {
                    "include": "#html-attribute-with-plate"
                },
                {
                    "include": "#html-attribute-with-plate-single"
                },
                {
                    "include": "text.html.basic#tag-stuff"
                }
            ]
        },
        "html-attribute-with-plate": {
            "begin": "(\\b[a-zA-Z_][\\w\\-:.]*)\\s*(=)\\s*(\")",
            "end": "\\3",
            "beginCaptures": {
                "1": {
                    "name": "entity.other.attribute-name.html"
                },
                "2": {
                    "name": "punctuation.separator.key-value.html"
                },
                "3": {
                    "name": "punctuation.definition.string.begin.html"
                }
            },
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.string.end.html"
                }
            },
            "patterns": [
                {
                    "include": "#plate-expression-in-string"
                }
            ]
        },
        "html-attribute-with-plate-single": {
            "begin": "(\\b[a-zA-Z_][\\w\\-:.]*)\\s*(=)\\s*(')",
            "end": "\\3",
            "beginCaptures": {
                "1": {
                    "name": "entity.other.attribute-name.html"
                },
                "2": {
                    "name": "punctuation.separator.key-value.html"
                },
                "3": {
                    "name": "punctuation.definition.string.begin.html"
                }
            },
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.string.end.html"
                }
            },
            "patterns": [
                {
                    "include": "#plate-expression-in-string"
                }
            ]
        },
        "plate-expression-in-string": {
            "begin": "\\{\\{",
            "end": "\\}\\}",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.definition.tag.begin.plate"
                }
            },
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.tag.end.plate"
                }
            },
            "contentName": "meta.embedded.line.plate",
            "patterns": [
                {
                    "include": "#plate-expression-content"
                }
            ]
        },
        "plate-directive": {
            "begin": "\\{\\{",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.definition.tag.begin.plate"
                }
            },
            "end": "\\}\\}",
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.tag.end.plate"
                }
            },
            "patterns": [
                {
                    "match": "\\s+",
                    "name": "meta.whitespace.plate"
                },
                {
                    "include": "#plate-comment"
                },
                {
                    "include": "#plate-keyword"
                },
                {
                    "include": "#plate-raw-php"
                },
                {
                    "match": "(==)([\\s\\S]*?)(?=\\}\\})",
                    "captures": {
                        "1": {
                            "name": "punctuation.definition.template-expression.plate"
                        },
                        "2": {
                            "name": "constant.character.escape.plate"
                        }
                    }
                },
                {
                    "include": "#plate-expression"
                }
            ]
        },
        "plate-comment": {
            "begin": "#",
            "end": "(?=\\}\\})",
            "name": "comment.line.number-sign.plate"
        },
        "plate-keyword": {
            "begin": "\\b(if|elseif|else|each)\\s*(:|;)",
            "beginCaptures": {
                "1": {
                    "name": "keyword.control.plate"
                },
                "2": {
                    "name": "punctuation.separator.plate"
                }
            },
            "end": "(?=\\}\\})",
            "patterns": [
                {
                    "match": "\\bas\\b",
                    "name": "keyword.control.loop.plate"
                },
                {
                    "include": "source.php"
                }
            ]
        },
        "plate-raw-php": {
            "begin": ":",
            "beginCaptures": {
                "0": {
                    "name": "keyword.other.raw-php.plate"
                }
            },
            "end": "(?=\\}\\})",
            "patterns": [
                {
                    "include": "source.php"
                }
            ]
        },
        "plate-expression": {
            "begin": "(?=\\$|\"|'|\\d|[a-zA-Z_])",
            "end": "(?=\\}\\})",
            "patterns": [
                {
                    "include": "#plate-expression-content"
                }
            ]
        },
        "plate-expression-content": {
            "patterns": [
                {
                    "include": "source.php"
                },
                {
                    "match": "\\$\\w+",
                    "name": "variable.other.plate"
                },
                {
                    "match": ",",
                    "name": "punctuation.separator.plate"
                }
            ]
        }
    }
}
